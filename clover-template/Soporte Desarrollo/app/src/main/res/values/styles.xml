<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/surface_primary</item>
    </style>

    <style name="AppTheme.Toolbar">
        <item name="android:background">@color/brand_primary</item>
        <item name="android:elevation">@dimen/elevation_card</item>
    </style>

    <!-- Typography styles -->
    <style name="TextCaption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextSecondary">
        <item name="android:textSize">@dimen/text_secondary_size</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextBody">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextSubheading">
        <item name="android:textSize">@dimen/text_subheading</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextHeading">
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextHeadline">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Button styles -->
    <style name="ButtonPrimary">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:minWidth">@dimen/button_min_width</item>
        <item name="android:background">@drawable/btn_primary_bg</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="ButtonDismiss">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:background">@drawable/btn_dismiss_bg</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_secondary_size</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Stat styles -->
    <style name="StatValue">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="StatLabel">
        <item name="android:textSize">@dimen/text_secondary_size</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>
