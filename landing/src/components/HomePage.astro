---
import BaseLayout from '../layouts/BaseLayout.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations } from '../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
---

<BaseLayout
	title={t.meta.title}
	description={t.meta.description}
	ogTitle={t.meta.ogTitle}
	ogDescription={t.meta.ogDescription}
	ogImage="https://nudge.404tf.com/nudge-cover.png"
>
	<!-- Nav -->
	<a href="#main-content" class="skip-link">{t.nav.skipToContent}</a>
	<header class="nav">
		<div class="container nav-inner">
			<a href={getRelativeLocaleUrl(locale, '')} class="nav-brand">
				<img src="/nudge-icon.png" alt="" width="32" height="32" class="nav-icon" />
				<span class="nav-wordmark">Nudge</span>
			</a>
			<nav class="nav-links">
				<a href="#how-it-works">{t.nav.howItWorks}</a>
				<a href="#features">{t.nav.features}</a>
			</nav>
			<div class="nav-actions">
				<LanguageSwitcher />
				<a href="https://cal.com/enrique-flores/nudge" target="_blank" rel="noopener" class="btn btn-accent btn-sm">{t.nav.bookDemo}</a>
			</div>
		</div>
	</header>

	<main>
		<!-- Hero -->
		<section class="hero" id="main-content">
			<div class="container hero-grid">
				<div class="hero-content">
					<span class="badge">{t.hero.badge}</span>
					<h1>{t.hero.heading}</h1>
					<p class="hero-sub">{t.hero.sub}</p>
					<div class="hero-ctas">
						<a href="https://cal.com/enrique-flores/nudge" target="_blank" rel="noopener" class="btn btn-accent btn-lg">
							{t.hero.ctaBook}
							<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
						</a>
						<a href="#how-it-works" class="btn btn-outline">{t.hero.ctaHow}</a>
					</div>
					<p class="hero-note">{t.hero.note}</p>
				</div>
				<div class="hero-visual">
					<div class="mockup-glow"></div>
					<div class="mockup-wrapper">
						<div class="mockup-order">
							<div class="mockup-order-bar">
								<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="2" stroke="currentColor" stroke-width="1.2"/><path d="M5 1v4M11 1v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
								<span>{t.mockup.order}</span>
								<span class="mockup-table">{t.mockup.table}</span>
							</div>
							<div class="mockup-items">
								<div class="mockup-line">
									<span>{t.mockup.item1}</span>
									<span>{t.mockup.price1}</span>
								</div>
								<div class="mockup-line">
									<span>{t.mockup.item2}</span>
									<span>{t.mockup.price2}</span>
								</div>
								<div class="mockup-line faded">
									<span>{t.mockup.subtotal}</span>
									<span>{t.mockup.subtotalPrice}</span>
								</div>
							</div>
						</div>
						<div class="mockup-card">
							<div class="mockup-card-accent"></div>
							<span class="mockup-label">{t.mockup.suggestedLabel}</span>
							<div class="mockup-card-row">
								<span class="mockup-name">{t.mockup.suggestName}</span>
								<span class="mockup-price">{t.mockup.suggestPrice}</span>
							</div>
							<p class="mockup-reason">{t.mockup.suggestReason}</p>
							<div class="mockup-btns">
								<span class="mockup-dismiss">{t.mockup.dismiss}</span>
								<span class="mockup-add">{t.mockup.addToOrder}</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Problem -->
		<section class="problem">
			<img src="/img/restaurant-busy.jpg" alt="" class="problem-bg" loading="lazy" />
			<div class="container">
				<h2 class="reveal">{t.problem.heading}</h2>
				<p class="section-sub reveal">{t.problem.sub}</p>
				<div class="problem-stats reveal-stagger">
					<div class="problem-stat">
						<span class="problem-num">{t.problem.stat1Num}</span>
						<span class="problem-label">{t.problem.stat1Label}</span>
					</div>
					<div class="problem-stat">
						<span class="problem-num">{t.problem.stat2Num}<span class="plus">{t.problem.stat2Plus}</span></span>
						<span class="problem-label">{t.problem.stat2Label}</span>
					</div>
					<div class="problem-stat">
						<span class="problem-num">{t.problem.stat3Num}</span>
						<span class="problem-label">{t.problem.stat3Label}</span>
					</div>
				</div>
			</div>
		</section>

		<!-- How It Works -->
		<section class="how" id="how-it-works">
			<div class="container">
				<h2 class="reveal">{t.how.heading}</h2>
				<p class="section-sub reveal">{t.how.sub}</p>
				<div class="steps reveal-stagger">
					<div class="step">
						<span class="step-num">01</span>
						<h3>{t.how.step1Title}</h3>
						<p>{t.how.step1Desc}</p>
					</div>
					<div class="step">
						<span class="step-num">02</span>
						<h3>{t.how.step2Title}</h3>
						<p>{t.how.step2Desc}</p>
					</div>
					<div class="step">
						<span class="step-num">03</span>
						<h3>{t.how.step3Title}</h3>
						<p>{t.how.step3Desc}</p>
					</div>
				</div>
				<div class="how-image reveal">
					<img src="/img/pos-device.jpg" alt="" loading="lazy" />
				</div>
			</div>
		</section>

		<!-- Features -->
		<section class="features" id="features">
			<div class="container">
				<h2 class="reveal">{t.features.heading}</h2>
				<p class="section-sub reveal">{t.features.sub}</p>
				<div class="features-grid reveal-stagger">
					<div class="feature-card">
						<div class="feature-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
						</div>
						<h3>{t.features.f1Title}</h3>
						<p>{t.features.f1Desc}</p>
					</div>
					<div class="feature-card">
						<div class="feature-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="7" opacity="0.4"/><circle cx="12" cy="12" r="10" opacity="0.15"/></svg>
						</div>
						<h3>{t.features.f2Title}</h3>
						<p>{t.features.f2Desc}</p>
					</div>
					<div class="feature-card">
						<div class="feature-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
						</div>
						<h3>{t.features.f3Title}</h3>
						<p>{t.features.f3Desc}</p>
					</div>
					<div class="feature-card">
						<div class="feature-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
						</div>
						<h3>{t.features.f4Title}</h3>
						<p>{t.features.f4Desc}</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Proof -->
		<section class="proof">
			<div class="container">
				<div class="proof-grid reveal-stagger">
					<div class="proof-item">
						<span class="proof-num">{t.proof.p1Num}</span>
						<span class="proof-label">{t.proof.p1Label}</span>
					</div>
					<div class="proof-item">
						<span class="proof-num">&lt;2s</span>
						<span class="proof-label">{t.proof.p2Label}</span>
					</div>
					<div class="proof-item">
						<span class="proof-num">{t.proof.p3Num}</span>
						<span class="proof-label">{t.proof.p3Label}</span>
					</div>
					<div class="proof-item">
						<span class="proof-num">{t.proof.p4Num}</span>
						<span class="proof-label">{t.proof.p4Label}</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Testimonial -->
		<section class="testimonial">
			<img src="/img/dining-table.jpg" alt="" class="testimonial-bg" loading="lazy" />
			<div class="container">
				<div class="testimonial-card reveal">
					<svg class="testimonial-quote-mark" width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
						<path d="M14 28c-3.3 0-6-2.7-6-6 0-6.6 5.4-12 12-12v4c-4.4 0-8 3.6-8 8h2c3.3 0 6 2.7 6 6s-2.7 6-6 6zm20 0c-3.3 0-6-2.7-6-6 0-6.6 5.4-12 12-12v4c-4.4 0-8 3.6-8 8h2c3.3 0 6 2.7 6 6s-2.7 6-6 6z" fill="currentColor"/>
					</svg>
					<blockquote class="testimonial-text">{t.testimonial.quote}</blockquote>
					<div class="testimonial-source">
						<span class="testimonial-name">{t.testimonial.attribution}</span>
						<span class="testimonial-context">{t.testimonial.context}</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="cta-final" id="early-access">
			<div class="container">
				<h2 class="reveal">{t.cta.heading}</h2>
				<p class="section-sub reveal">{t.cta.sub}</p>
				<div class="cta-final-actions reveal">
					<a href="https://cal.com/enrique-flores/nudge" target="_blank" rel="noopener" class="btn btn-accent btn-lg">
						{t.cta.button}
						<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
					</a>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="footer">
		<div class="container footer-inner">
			<div class="footer-brand">
				<img src="/nudge-icon.png" alt="" width="24" height="24" />
				<span>Nudge</span>
			</div>
			<nav class="footer-links">
				<a href="#how-it-works">{t.footer.howItWorks}</a>
				<a href="#features">{t.footer.features}</a>
				<a href={getRelativeLocaleUrl(locale, 'privacy')}>{t.footer.privacy}</a>
				<a href={getRelativeLocaleUrl(locale, 'eula')}>{t.footer.terms}</a>
			</nav>
			<p class="footer-copy">&copy; 2026 Enrique Flores. All rights reserved.</p>
		</div>
	</footer>

	<script>
		document.documentElement.classList.add('js');

		// Nav scroll state
		const nav = document.querySelector('.nav');
		let ticking = false;
		window.addEventListener('scroll', () => {
			if (!ticking) {
				requestAnimationFrame(() => {
					nav?.classList.toggle('nav-scrolled', window.scrollY > 20);
					ticking = false;
				});
				ticking = true;
			}
		}, { passive: true });

		// Scroll reveal
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

		document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => observer.observe(el));
	</script>
</BaseLayout>

<style is:global>
	:root {
		--brand: #1B6B4A;
		--brand-light: #2A8C63;
		--brand-dark: #0F4D35;
		--brand-surface: #E8F5EE;
		--accent: #E8720C;
		--accent-light: #FF8F2E;
		--accent-surface: #FFF3E6;
		--surface-1: #FAFBF9;
		--surface-2: #F2F4F0;
		--surface-card: #FEFFFE;
		--text-1: #1A2B23;
		--text-2: #5A6B63;
		--text-3: #8A9B93;
		--text-on-brand: #F5FBF8;
		--border: #E2E8E4;
		--border-strong: #C5CEC8;
		--success: #1B8C5A;
		--font-display: 'Instrument Serif', Georgia, serif;
		--font-body: 'DM Sans', system-ui, -apple-system, sans-serif;
		--shadow-sm: 0 1px 3px rgba(26,43,35,.06), 0 1px 2px rgba(26,43,35,.04);
		--shadow-md: 0 4px 12px rgba(26,43,35,.08), 0 2px 4px rgba(26,43,35,.04);
		--shadow-lg: 0 12px 32px rgba(26,43,35,.1), 0 4px 8px rgba(26,43,35,.05);
		--shadow-xl: 0 20px 48px rgba(26,43,35,.14), 0 8px 16px rgba(26,43,35,.06);
		--r-sm: 8px;
		--r-md: 12px;
		--r-lg: 16px;
		--ease-out: cubic-bezier(0.23, 1, 0.32, 1);
		--ease-in-out: cubic-bezier(0.77, 0, 0.175, 1);
		--ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

	html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

	body {
		font-family: var(--font-body);
		font-size: 16px;
		line-height: 1.6;
		color: var(--text-1);
		background: var(--surface-1);
	}

	img { max-width: 100%; height: auto; display: block; }
	a { color: inherit; text-decoration: none; }
	button, input { font-family: inherit; font-size: inherit; border: none; }
	button { cursor: pointer; background: none; }
	:focus-visible {
		outline: 2px solid var(--brand);
		outline-offset: 2px;
	}
	input:focus-visible { outline: none; }
	button:disabled { opacity: 0.6; cursor: not-allowed; }

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 24px;
	}

	/* Skip Link */

	.skip-link {
		position: fixed;
		top: -100%;
		left: 16px;
		z-index: 200;
		padding: 8px 16px;
		background: var(--brand);
		color: var(--text-on-brand);
		border-radius: var(--r-sm);
		font-size: 14px;
		font-weight: 600;
		transition: top 200ms var(--ease-out);
	}
	.skip-link:focus {
		top: 12px;
	}

	/* Buttons */

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 14px 28px;
		border-radius: var(--r-md);
		font-weight: 600;
		font-size: 15px;
		letter-spacing: -0.01em;
		transition: transform 160ms var(--ease-out), background 200ms ease, box-shadow 200ms ease;
		white-space: nowrap;
	}
	.btn:active { transform: scale(0.97); }
	.btn-accent {
		background: var(--accent);
		color: #FFFCF8;
	}
	@media (hover: hover) and (pointer: fine) {
		.btn-accent:hover {
			background: var(--accent-light);
			transform: translateY(-1px);
			box-shadow: var(--shadow-md);
		}
	}
	.btn-sm { padding: 10px 20px; font-size: 14px; }
	.btn-lg { padding: 16px 32px; font-size: 16px; }
	.btn-outline {
		border: 1px solid var(--border-strong);
		color: var(--text-2);
		padding: 14px 28px;
	}
	@media (hover: hover) and (pointer: fine) {
		.btn-outline:hover {
			border-color: var(--brand);
			color: var(--brand);
		}
	}
	.btn-brand {
		background: var(--brand);
		color: var(--text-on-brand);
	}
	@media (hover: hover) and (pointer: fine) {
		.btn-brand:hover {
			background: var(--brand-light);
			transform: translateY(-1px);
			box-shadow: var(--shadow-md);
		}
	}
	.btn-success { background: var(--success); }
	.btn-success:hover { background: var(--success); transform: none; box-shadow: none; }

	/* Nav */

	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: 14px 0;
		background: rgba(250,251,249,.85);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border);
		transition: background 300ms ease, box-shadow 300ms ease;
	}
	.nav.nav-scrolled {
		background: rgba(250,251,249,.97);
		box-shadow: var(--shadow-sm);
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-brand {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.nav-icon { width: 32px; height: 32px; border-radius: var(--r-sm); }
	.nav-wordmark {
		font-family: var(--font-display);
		font-size: 22px;
		color: var(--text-1);
	}
	.nav-links {
		display: none;
		gap: 36px;
	}
	.nav-links a {
		font-size: 15px;
		font-weight: 500;
		color: var(--text-2);
		transition: color 200ms ease;
	}
	.nav-links a:hover { color: var(--text-1); }
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	@media (min-width: 768px) {
		.nav-links { display: flex; }
	}

	/* Hero */

	.hero {
		padding: 120px 0 80px;
		overflow: hidden;
	}
	.hero-grid {
		display: grid;
		gap: 48px;
		align-items: center;
	}

	.badge {
		display: inline-block;
		padding: 6px 16px;
		background: var(--brand-surface);
		color: var(--brand);
		border-radius: 100px;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.01em;
		margin-bottom: 24px;
	}

	h1 {
		font-family: var(--font-display);
		font-size: 42px;
		line-height: 1.08;
		color: var(--text-1);
		letter-spacing: -0.025em;
		margin-bottom: 20px;
	}

	.hero-sub {
		font-size: 18px;
		line-height: 1.65;
		color: var(--text-2);
		margin-bottom: 32px;
		max-width: 520px;
	}

	.cta-form {
		display: flex;
		flex-direction: column;
		gap: 12px;
		max-width: 480px;
	}
	.cta-form input {
		width: 100%;
		padding: 14px 20px;
		background: var(--surface-card);
		border: 1px solid var(--border);
		border-radius: var(--r-md);
		color: var(--text-1);
		font-size: 16px;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.cta-form input::placeholder { color: var(--text-3); }
	.cta-form input:focus {
		border-color: var(--brand);
		box-shadow: 0 0 0 3px rgba(27,107,74,.1);
	}
	.cta-form input:disabled {
		opacity: 0.6;
	}

	.hero-ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.hero-note {
		margin-top: 16px;
		font-size: 13px;
		color: var(--text-3);
	}

	/* Hero entrance stagger */
	html.js .hero-content > * {
		opacity: 0;
		animation: heroFadeUp 600ms var(--ease-out) forwards;
	}
	html.js .hero-content > :nth-child(1) { animation-delay: 100ms; }
	html.js .hero-content > :nth-child(2) { animation-delay: 200ms; }
	html.js .hero-content > :nth-child(3) { animation-delay: 320ms; }
	html.js .hero-content > :nth-child(4) { animation-delay: 440ms; }
	html.js .hero-content > :nth-child(5) { animation-delay: 540ms; }

	@keyframes heroFadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (min-width: 768px) {
		.hero { padding: 160px 0 100px; }
		.hero-grid { grid-template-columns: 1fr 1fr; gap: 64px; }
		h1 { font-size: 60px; }
		.cta-form { flex-direction: row; gap: 8px; }
	}

	/* Hero Mockup */

	.hero-visual {
		position: relative;
		display: flex;
		justify-content: center;
	}
	.mockup-glow {
		position: absolute;
		width: 340px;
		height: 340px;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		background: radial-gradient(circle, var(--brand-surface) 0%, transparent 70%);
		border-radius: 50%;
		pointer-events: none;
	}
	.mockup-wrapper {
		position: relative;
		width: 100%;
		max-width: 380px;
		animation: mockup-float 6s ease-in-out 1.6s infinite;
	}

	html.js .mockup-order {
		opacity: 0;
		animation: heroFadeUp 500ms var(--ease-out) 300ms forwards;
	}

	.mockup-order {
		background: var(--surface-card);
		border: 1px solid var(--border);
		border-radius: var(--r-lg);
		padding: 20px;
		box-shadow: var(--shadow-sm);
	}
	.mockup-order-bar {
		display: flex;
		align-items: center;
		gap: 8px;
		padding-bottom: 14px;
